@model crud_adventureworks2019.Models.Personas

@{
    ViewBag.Title = "Crear Nueva Persona";
}

<h2>Crear Nueva Persona</h2>

@using (Html.BeginForm())
{
    <div class="form-group">
        @Html.LabelFor(m => m.PersonType)
        @Html.TextBoxFor(m => m.PersonType, new { @class = "form-control", placeholder = "Tipo de persona" })
        @Html.ValidationMessageFor(m => m.PersonType, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.FirstName)
        @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "Nombre" })
        @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.LastName)
        @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Apellido" })
        @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
    </div>

    <button type="submit" class="btn btn-primary">Crear</button>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Cancelar</a>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}