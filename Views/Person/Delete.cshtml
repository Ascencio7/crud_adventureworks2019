@model crud_adventureworks2019.Models.Personas

@{
    ViewBag.Title = "Eliminar Persona";
}

<h2>Eliminar Persona</h2>

<h4>¿Está seguro que desea eliminar esta persona?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-2">Tipo</dt>
        <dd class="col-sm-10">@Model.PersonType</dd>

        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.FirstName</dd>

        <dt class="col-sm-2">Apellido</dt>
        <dd class="col-sm-10">@Model.LastName</dd>
    </dl>
</div>

@using (Html.BeginForm("Delete", "Person", FormMethod.Post))
{
    @Html.HiddenFor(m => m.BusinessEntityID)
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Cancelar</a>
}